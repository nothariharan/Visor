// src/components/GraphCanvas.jsx

import ReactFlow, { 
  Background, 
  Controls,
  MarkerType 
} from 'reactflow';

export function GraphCanvas() {
  const nodes = useGraphStore(state => state.nodes);
  const edges = useGraphStore(state => state.edges);
  
  // Edge types
  const edgeTypes = {
    default: CustomEdge,
  };
  
  return (
    <ReactFlow
      nodes={nodes}
      edges={edges}
      edgeTypes={edgeTypes}
      
      // Important: Enable edge labels
      defaultEdgeOptions={{
        type: 'smoothstep',  // or 'default', 'straight', 'step'
        markerEnd: {
          type: MarkerType.ArrowClosed,
        }
      }}
      
      fitView
      minZoom={0.1}
      maxZoom={2}
    >
      <Background />
      <Controls />
      
      {/* Add legend */}
      <EdgeLegend />
    </ReactFlow>
  );
}
```

#### Step 3.2: Create Custom Edge Component (Optional)

```javascript
// src/components/CustomEdge.jsx

import { getBezierPath } from 'reactflow';

export function CustomEdge({
  id,
  sourceX,
  sourceY,
  targetX,
  targetY,
  sourcePosition,
  targetPosition,
  style,
  markerEnd,
  data
}) {
  const [edgePath] = getBezierPath({
    sourceX,
    sourceY,
    sourcePosition,
    targetX,
    targetY,
    targetPosition,
  });
  
  return (
    <>
      <path
        id={id}
        className="react-flow__edge-path"
        d={edgePath}
        style={style}
        markerEnd={markerEnd}
      />
      
      {/* Optional: Add label */}
      {data?.label && (
        <text>
          <textPath href={`#${id}`} startOffset="50%" textAnchor="middle">
            {data.label}
          </textPath>
        </text>
      )}
    </>
  );
}
```

