## Implementation Strategy

### Phase 1: Backend - Dependency Parsing

#### Step 1.1: Install Required Libraries

```bash
# In your backend directory
npm install @babel/parser @babel/traverse
npm install parse5  # For HTML parsing
npm install postcss postcss-import  # For CSS parsing
npm install resolve  # For path resolution
```

**Why these libraries?**
- `@babel/parser` - Parses JavaScript/JSX/TypeScript into AST (Abstract Syntax Tree)
- `@babel/traverse` - Walks through AST to find import statements
- `parse5` - Parses HTML to find `<link>` and `<script>` tags
- `postcss` - Parses CSS to find `@import` statements
- `resolve` - Resolves module paths like Node.js does

---

#### Step 1.2: Create Dependency Analyzer Module

```javascript
// server/analyzer/DependencyAnalyzer.js

import fs from 'fs/promises';
import path from 'path';
import { parse as babelParse } from '@babel/parser';
import traverse from '@babel/traverse';
import { parse as htmlParse } from 'parse5';
import postcss from 'postcss';
import resolve from 'resolve';

export class DependencyAnalyzer {
  constructor(projectRoot, config) {
    this.projectRoot = projectRoot;
    this.config = config;
    
    // Cache for resolved paths
    this.resolveCache = new Map();
  }
  
  /**
   * Main entry point - analyze all files and return graph
   */
  async analyzeProject() {
    const files = await this.scanFiles(this.projectRoot);
    
    const nodes = [];
    const edges = [];
    
    for (const filePath of files) {
      // Create node
      const node = await this.createNode(filePath);
      nodes.push(node);
      
      // Extract dependencies
      const dependencies = await this.extractDependencies(filePath);
      
      // Create edges
      for (const dep of dependencies) {
        const edge = this.createEdge(filePath, dep);
        if (edge) edges.push(edge);
      }
    }
    
    return { nodes, edges };
  }
  
  /**
   * Extract dependencies based on file type
   */
  async extractDependencies(filePath) {
    const ext = path.extname(filePath);
    const content = await fs.readFile(filePath, 'utf-8');
    
    switch (ext) {
      case '.html':
        return this.parseHTML(content, filePath);
      
      case '.css':
      case '.scss':
      case '.less':
        return this.parseCSS(content, filePath);
      
      case '.js':
      case '.jsx':
      case '.ts':
      case '.tsx':
        return this.parseJavaScript(content, filePath);
      
      default:
        return [];
    }
  }
  
  /**
   * Parse HTML files for <link> and <script> tags
   */
  parseHTML(content, filePath) {
    const dependencies = [];
    const document = htmlParse(content);
    
    const walk = (node) => {
      if (node.tagName === 'link') {
        // <link rel="stylesheet" href="styles.css">
        const href = node.attrs?.find(a => a.name === 'href')?.value;
        const rel = node.attrs?.find(a => a.name === 'rel')?.value;
        
        if (href) {
          dependencies.push({
            module: href,
            type: rel === 'stylesheet' ? 'css' : 'resource',
            importType: 'link-tag',
            line: node.sourceCodeLocation?.startLine
          });
        }
      }
      
      if (node.tagName === 'script') {
        // <script src="app.js"></script>
        const src = node.attrs?.find(a => a.name === 'src')?.value;
        const type = node.attrs?.find(a => a.name === 'type')?.value;
        
        if (src) {
          dependencies.push({
            module: src,
            type: type === 'module' ? 'es-module' : 'script',
            importType: 'script-tag',
            line: node.sourceCodeLocation?.startLine
          });
        }
      }
      
      // Recursively walk children
      if (node.childNodes) {
        node.childNodes.forEach(walk);
      }
    };
    
    walk(document);
    
    return dependencies;
  }
  
  /**
   * Parse CSS files for @import statements
   */
  async parseCSS(content, filePath) {
    const dependencies = [];
    
    try {
      const result = await postcss().process(content, { from: filePath });
      
      result.root.walkAtRules('import', (rule) => {
        // @import "other.css"
        // @import url("other.css")
        let importPath = rule.params.replace(/['"]/g, '').replace(/url\((.*)\)/, '$1').trim();
        
        dependencies.push({
          module: importPath,
          type: 'css',
          importType: 'css-import',
          line: rule.source?.start?.line
        });
      });
    } catch (error) {
      console.error(`Error parsing CSS ${filePath}:`, error.message);
    }
    
    return dependencies;
  }
  
  /**
   * Parse JavaScript/JSX/TypeScript for import/require statements
   */
  parseJavaScript(content, filePath) {
    const dependencies = [];
    
    try {
      // Parse with Babel (supports JSX, TS, modern syntax)
      const ast = babelParse(content, {
        sourceType: 'module',
        plugins: [
          'jsx',
          'typescript',
          'classProperties',
          'dynamicImport'
        ]
      });
      
      // Traverse AST to find import statements
      traverse(ast, {
        // import React from 'react'
        // import { useState } from 'react'
        // import * as Utils from './utils'
        ImportDeclaration(path) {
          const importPath = path.node.source.value;
          const specifiers = path.node.specifiers;
          
          // Determine import type
          let importType = 'named';
          if (specifiers.some(s => s.type === 'ImportDefaultSpecifier')) {
            importType = 'default';
          } else if (specifiers.some(s => s.type === 'ImportNamespaceSpecifier')) {
            importType = 'namespace';
          }
          
          dependencies.push({
            module: importPath,
            type: this.classifyModule(importPath),
            importType,
            line: path.node.loc?.start?.line
          });
        },
        
        // const React = require('react')
        CallExpression(path) {
          if (path.node.callee.name === 'require' && 
              path.node.arguments[0]?.type === 'StringLiteral') {
            const requirePath = path.node.arguments[0].value;
            
            dependencies.push({
              module: requirePath,
              type: this.classifyModule(requirePath),
              importType: 'require',
              line: path.node.loc?.start?.line
            });
          }
          
          // import('dynamic-module')
          if (path.node.callee.type === 'Import') {
            const importPath = path.node.arguments[0]?.value;
            
            dependencies.push({
              module: importPath,
              type: this.classifyModule(importPath),
              importType: 'dynamic',
              line: path.node.loc?.start?.line
            });
          }
        }
      });
      
    } catch (error) {
      console.error(`Error parsing JavaScript ${filePath}:`, error.message);
    }
    
    return dependencies;
  }
  
  /**
   * Classify module type based on import path
   */
  classifyModule(modulePath) {
    // CSS files
    if (/\.(css|scss|sass|less)$/i.test(modulePath)) return 'css';
    
    // Image files
    if (/\.(png|jpg|jpeg|gif|svg|webp)$/i.test(modulePath)) return 'image';
    
    // JSON/Data files
    if (/\.(json|yaml|yml)$/i.test(modulePath)) return 'data';
    
    // Node modules (no ./ or ../)
    if (!modulePath.startsWith('.') && !modulePath.startsWith('/')) {
      return 'node_module';
    }
    
    // React/Vue components (uppercase first letter or .jsx/.vue)
    if (/\.(jsx|tsx|vue)$/i.test(modulePath) || /^[A-Z]/.test(path.basename(modulePath))) {
      return 'component';
    }
    
    // Utility/Helper files
    if (/(util|helper|lib|service)/i.test(modulePath)) {
      return 'utility';
    }
    
    // Default: JavaScript module
    return 'module';
  }
  
  /**
   * Resolve module path to absolute file path
   */
  async resolvePath(modulePath, fromFile) {
    const cacheKey = `${fromFile}::${modulePath}`;
    
    // Check cache
    if (this.resolveCache.has(cacheKey)) {
      return this.resolveCache.get(cacheKey);
    }
    
    let resolved = null;
    
    try {
      // Handle different path types
      if (modulePath.startsWith('.')) {
        // Relative path: ./Button.jsx
        resolved = await this.resolveRelativePath(modulePath, fromFile);
      } else if (modulePath.startsWith('@/')) {
        // Alias path: @/components/Button
        resolved = await this.resolveAliasPath(modulePath);
      } else {
        // Node module: react, lodash
        // For visualization, we might skip these or show as external
        resolved = null;  // Or: { external: true, module: modulePath }
      }
    } catch (error) {
      console.warn(`Could not resolve: ${modulePath} from ${fromFile}`);
    }
    
    // Cache result
    this.resolveCache.set(cacheKey, resolved);
    
    return resolved;
  }
  
  /**
   * Resolve relative paths (./Button.jsx, ../utils/format)
   */
  async resolveRelativePath(modulePath, fromFile) {
    const dir = path.dirname(fromFile);
    let resolved = path.resolve(dir, modulePath);
    
    // Try adding common extensions if file doesn't exist
    const extensions = ['.js', '.jsx', '.ts', '.tsx', '.json', ''];
    
    for (const ext of extensions) {
      const withExt = resolved + ext;
      try {
        await fs.access(withExt);
        return withExt;  // File exists
      } catch {
        // Try next extension
      }
    }
    
    // Try index files in directory
    const indexFiles = ['index.js', 'index.jsx', 'index.ts', 'index.tsx'];
    for (const indexFile of indexFiles) {
      const indexPath = path.join(resolved, indexFile);
      try {
        await fs.access(indexPath);
        return indexPath;
      } catch {
        // Continue
      }
    }
    
    return null;  // Could not resolve
  }
  
  /**
   * Resolve alias paths (@/components/Button → src/components/Button)
   */
  async resolveAliasPath(modulePath) {
    // Read tsconfig.json or jsconfig.json for path aliases
    const tsconfigPath = path.join(this.projectRoot, 'tsconfig.json');
    const jsconfigPath = path.join(this.projectRoot, 'jsconfig.json');
    
    let config = null;
    
    try {
      const tsconfigContent = await fs.readFile(tsconfigPath, 'utf-8');
      config = JSON.parse(tsconfigContent);
    } catch {
      try {
        const jsconfigContent = await fs.readFile(jsconfigPath, 'utf-8');
        config = JSON.parse(jsconfigContent);
      } catch {
        // No config file found
      }
    }
    
    if (!config?.compilerOptions?.paths) {
      return null;
    }
    
    const paths = config.compilerOptions.paths;
    const baseUrl = config.compilerOptions.baseUrl || '.';
    
    // Find matching alias
    for (const [alias, targets] of Object.entries(paths)) {
      const aliasPattern = alias.replace('/*', '');
      
      if (modulePath.startsWith(aliasPattern)) {
        const relativePath = modulePath.replace(aliasPattern, '');
        const targetPattern = targets[0].replace('/*', '');
        const resolved = path.join(this.projectRoot, baseUrl, targetPattern, relativePath);
        
        return this.resolveRelativePath('./' + path.relative(path.dirname(resolved), resolved), resolved);
      }
    }
    
    return null;
  }
  
  /**
   * Create edge from dependency information
   */
  async createEdge(fromFile, dependency) {
    const resolvedPath = await this.resolvePath(dependency.module, fromFile);
    
    if (!resolvedPath) {
      // Could not resolve - skip or create external node
      return null;
    }
    
    // Assign color based on dependency type
    const edgeStyle = this.getEdgeStyle(dependency.type, dependency.importType);
    
    return {
      id: `${fromFile}→${resolvedPath}`,
      source: fromFile,
      target: resolvedPath,
      
      // Metadata
      type: dependency.type,
      importType: dependency.importType,
      line: dependency.line,
      
      // Styling
      ...edgeStyle,
      
      // React Flow properties
      animated: dependency.importType === 'dynamic',
      label: dependency.importType === 'dynamic' ? '⚡ Dynamic' : ''
    };
  }
  
  /**
   * Get edge styling based on dependency type
   */
  getEdgeStyle(type, importType) {
    // Color scheme
    const colors = {
      css: '#3b82f6',           // Blue
      module: '#eab308',        // Yellow
      component: '#10b981',     // Green
      utility: '#8b5cf6',       // Purple
      image: '#ec4899',         // Pink
      data: '#f97316',          // Orange
      node_module: '#6b7280',   // Gray
      script: '#fbbf24'         // Amber
    };
    
    return {
      style: {
        stroke: colors[type] || '#888',
        strokeWidth: 2,
        strokeDasharray: importType === 'dynamic' ? '5,5' : '0'
      },
      markerEnd: {
        type: 'arrowclosed',
        color: colors[type] || '#888',
        width: 20,
        height: 20
      }
    };
  }
}
